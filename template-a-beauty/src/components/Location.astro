---
import { siteData } from '../data/site';
---

<section id="location" class="py-16 px-4 bg-white">
  <div class="max-w-7xl mx-auto">
    <!-- Title -->
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-center text-skin-base mb-12">
      店家位置
    </h2>

    <!-- Two Column Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Left: Contact Info -->
      <div class="flex flex-col justify-center space-y-6">
        <!-- Address -->
        <div>
          <h3 class="font-serif font-bold text-skin-base mb-2">位置</h3>
          <p class="text-gray-700">{siteData.address}</p>
        </div>

        <!-- Business Hours -->
        <div>
          <h3 class="font-serif font-bold text-skin-base mb-2">營業時間</h3>
          <p class="text-gray-700">{siteData.businessHours}</p>
        </div>

        <!-- Contact Buttons -->
        <div class="flex flex-col sm:flex-row gap-4">
          <!-- Phone Button -->
          <a
            href={`tel:${siteData.phone}`}
            class="flex items-center justify-center gap-2 bg-skin-primary text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition"
          >
            <span>☎️</span>
            <span>撥打電話</span>
          </a>

          <!-- LINE Button -->
          <a
            href={siteData.lineUrl}
            target="_blank"
            rel="noopener"
            class="flex items-center justify-center gap-2 bg-skin-secondary text-skin-base px-6 py-3 rounded-lg font-semibold hover:bg-opacity-80 transition border border-skin-primary"
          >
            <span>💬</span>
            <span>加入 LINE</span>
          </a>
        </div>
      </div>

      <!-- Right: Google Map -->
      <div class="rounded-2xl overflow-hidden shadow-md">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3681.4290264550244!2d120.27484987624062!3d22.567890771139567!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3471d6c7d6b6b6b7%3A0x6b6b6b6b6b6b6b6b!2z6auY5rW35rOw5YiX57iE6YKS6YKS!5e0!3m2!1szh-TW!2stw!4v1234567890123"
          width="100%"
          height="300"
          style="border:0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>
