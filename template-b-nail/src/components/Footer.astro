---
import { siteData } from '../data/site';
---

<footer class="bg-[#0D0D1A] border-t border-[#252540]">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <!-- Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <!-- Shop Info -->
      <div>
        <h3 class="text-2xl font-serif text-skin-primary mb-4">{siteData.shopName}</h3>
        <p class="text-sm text-gray-400">{siteData.tagline}</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-serif text-skin-accent mb-4">快速連結</h4>
        <ul class="space-y-2">
          <li>
            <a href="#services" class="text-gray-400 hover:text-skin-accent transition-colors duration-300">服務項目</a>
          </li>
          <li>
            <a href="#gallery" class="text-gray-400 hover:text-skin-accent transition-colors duration-300">作品集</a>
          </li>
          <li>
            <a href="#trust" class="text-gray-400 hover:text-skin-accent transition-colors duration-300">客戶評價</a>
          </li>
          <li>
            <a href="#location" class="text-gray-400 hover:text-skin-accent transition-colors duration-300">位置資訊</a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-lg font-serif text-skin-accent mb-4">聯絡資訊</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li>
            <a href={`tel:${siteData.phone}`} class="hover:text-skin-accent transition-colors duration-300">
              {siteData.phone}
            </a>
          </li>
          <li>{siteData.address}</li>
          <li>{siteData.businessHours}</li>
        </ul>
      </div>

      <!-- Social Links -->
      <div>
        <h4 class="text-lg font-serif text-skin-accent mb-4">追蹤我們</h4>
        <div class="flex gap-4">
          <a
            href={siteData.lineUrl}
            target="_blank"
            rel="noopener"
            title="LINE 官方帳號"
            class="text-gray-400 hover:text-skin-accent transition-colors duration-300"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.365 9.863c.349-1.864-.563-3.642-2.273-4.915-1.922-1.439-4.957-2.572-8.092-2.572-5.336 0-9.927 3.224-9.927 8.451 0 2.548 1.36 4.847 3.56 6.364-.156.85-.968 4.733-1.053 5.447-.118.953.757 1.78 1.664 1.28 1.291-.777 6.892-4.152 8.634-5.365 1.613.315 3.286.42 5.002.42 5.336 0 9.926-3.224 9.926-8.452-.001-3.968-2.57-7.39-6.441-8.258z"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-[#353553] to-transparent my-8"></div>

    <!-- Bottom Section -->
    <div class="flex flex-col md:flex-row justify-between items-center text-sm text-gray-500">
      <p>&copy; 2024 {siteData.shopName}. 版權所有。</p>
      <div class="flex gap-6 mt-4 md:mt-0">
        <a href="#" class="hover:text-skin-accent transition-colors duration-300">隱私政策</a>
        <a href="#" class="hover:text-skin-accent transition-colors duration-300">服務條款</a>
      </div>
    </div>
  </div>
</footer>
