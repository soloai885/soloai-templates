---
import { siteData } from '../data/site';

---

<section id="location" class="py-20 px-6 bg-[#1A1A2E]">
  <div class="max-w-6xl mx-auto">
    <!-- Title -->
    <h2 class="text-4xl md:text-5xl font-serif text-skin-primary text-center mb-16">
      位置資訊
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Info Card -->
      <div class="space-y-8">
        <!-- Address -->
        <div class="bg-[#252540] p-8 rounded-lg border border-[#353553]">
          <h3 class="text-2xl font-serif text-skin-accent mb-4">地址</h3>
          <p class="text-lg text-skin-base mb-4">{siteData.address}</p>
          <a
            href={siteData.googleMapsUrl}
            target="_blank"
            rel="noopener"
            class="inline-block px-6 py-2 bg-skin-accent text-white rounded-lg hover:bg-[#c97be6] transition-all duration-300"
          >
            在 Google 地圖開啟
          </a>
        </div>

        <!-- Business Hours -->
        <div class="bg-[#252540] p-8 rounded-lg border border-[#353553]">
          <h3 class="text-2xl font-serif text-skin-accent mb-4">營業時間</h3>
          <p class="text-lg text-skin-base">{siteData.businessHours}</p>
          <p class="text-sm text-gray-400 mt-4">☐ 週一 公休</p>
        </div>

        <!-- Contact -->
        <div class="bg-[#252540] p-8 rounded-lg border border-[#353553]">
          <h3 class="text-2xl font-serif text-skin-accent mb-6">聯絡我們</h3>
          <div class="space-y-4">
            <div>
              <p class="text-sm text-gray-400 mb-2">電話</p>
              <a
                href={`tel:${siteData.phone}`}
                class="text-lg text-skin-base hover:text-skin-accent transition-colors duration-300"
              >
                {siteData.phone}
              </a>
            </div>
            <div>
              <p class="text-sm text-gray-400 mb-2">LINE 官方帳號</p>
              <a
                href={siteData.lineUrl}
                target="_blank"
                rel="noopener"
                class="inline-block px-6 py-2 bg-[#1A1A2E] border border-skin-accent text-skin-accent rounded-lg hover:bg-skin-accent hover:text-white transition-all duration-300"
              >
                加入 LINE 好友
              </a>
            </div>
          </div>
        </div>

        <!-- CTA Button -->
        <button
          onclick="document.getElementById('booking-form')?.scrollIntoView({ behavior: 'smooth' })"
          class="w-full px-8 py-4 bg-skin-primary text-white font-semibold rounded-lg hover:bg-[#8a4a9d] transition-all duration-300 transform hover:scale-105 text-lg"
        >
          立即預約
        </button>
      </div>

    <iframe
          src={`https://www.google.com/maps?q=${encodeURIComponent(siteData.address)}&output=embed`}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </div>
</section>
