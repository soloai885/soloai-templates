---
import { siteData } from '../data/site';
---

<section id="services" class="py-20 px-6 bg-[#1A1A2E]">
  <div class="max-w-6xl mx-auto">
    <!-- Title -->
    <h2 class="text-4xl md:text-5xl font-serif text-skin-primary text-center mb-16">
      我們的服務
    </h2>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {siteData.services.map((service) => (
        <div
          class="bg-[#252540] p-6 rounded-lg border border-[#353553] hover:border-skin-accent hover:shadow-[0_0_15px_rgba(217,142,240,0.3)] transition-all duration-300 group"
        >
          <!-- Icon -->
          <div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300">
            {service.icon}
          </div>

          <!-- Service Name -->
          <h3 class="text-xl font-serif text-skin-base mb-3 group-hover:text-skin-accent transition-colors duration-300">
            {service.name}
          </h3>

          <!-- Service Details -->
          <div class="space-y-2 mb-4">
            <p class="text-sm text-gray-400">
              <span class="font-semibold">價格：</span>{service.price}
            </p>
            <p class="text-sm text-gray-400">
              <span class="font-semibold">時長：</span>{service.duration}
            </p>
          </div>

          <!-- Divider -->
          <div class="h-px bg-gradient-to-r from-transparent via-skin-accent to-transparent opacity-50 mb-4"></div>

          <!-- Service Image -->
          <img
            src="/placeholder/card.jpg"
            alt={service.name}
            loading="lazy"
            class="w-full aspect-video object-cover rounded-lg group-hover:opacity-80 transition-opacity duration-300"
          />
        </div>
      ))}
    </div>
  </div>
</section>
