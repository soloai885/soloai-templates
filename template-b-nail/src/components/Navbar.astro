---
import { siteData } from '../data/site';
---

<nav class="fixed top-0 w-full z-50 bg-[#1A1A2E] border-b border-[#252540]">
  <div class="max-w-6xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo/Shop Name -->
      <div class="flex-1">
        <h1 class="text-2xl font-serif text-skin-primary tracking-wide">{siteData.shopName}</h1>
      </div>

      <!-- Nav Links - Hidden on mobile, visible on md+ -->
      <div class="hidden md:flex flex-1 justify-center gap-8">
        <a href="#services" class="text-skin-base hover:text-skin-accent transition-colors duration-300">服務項目</a>
        <a href="#gallery" class="text-skin-base hover:text-skin-accent transition-colors duration-300">作品集</a>
        <a href="#location" class="text-skin-base hover:text-skin-accent transition-colors duration-300">位置資訊</a>
      </div>

      <!-- CTA Buttons -->
      <div class="flex-1 flex justify-end items-center gap-3">
        <!-- Phone CTA -->
        <a href={`tel:${siteData.phone}`} class="hidden sm:inline-block text-skin-base hover:text-skin-accent transition-colors duration-300" title="撥打電話">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
        </a>

        <!-- LINE CTA -->
        <a href={siteData.lineUrl} target="_blank" rel="noopener" class="hidden sm:inline-block text-skin-base hover:text-skin-accent transition-colors duration-300" title="加入 LINE">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19.365 9.863c.349-1.864-.563-3.642-2.273-4.915-1.922-1.439-4.957-2.572-8.092-2.572-5.336 0-9.927 3.224-9.927 8.451 0 2.548 1.36 4.847 3.56 6.364-.156.85-.968 4.733-1.053 5.447-.118.953.757 1.78 1.664 1.28 1.291-.777 6.892-4.152 8.634-5.365 1.613.315 3.286.42 5.002.42 5.336 0 9.926-3.224 9.926-8.452-.001-3.968-2.57-7.39-6.441-8.258z"></path>
          </svg>
        </a>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-toggle" class="md:hidden text-skin-base hover:text-skin-accent transition-colors duration-300">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-[#252540]">
      <div class="flex flex-col gap-4 mt-4">
        <a href="#services" class="text-skin-base hover:text-skin-accent transition-colors duration-300">服務項目</a>
        <a href="#gallery" class="text-skin-base hover:text-skin-accent transition-colors duration-300">作品集</a>
        <a href="#location" class="text-skin-base hover:text-skin-accent transition-colors duration-300">位置資訊</a>
        <a href={`tel:${siteData.phone}`} class="text-skin-base hover:text-skin-accent transition-colors duration-300">電話：{siteData.phone}</a>
        <a href={siteData.lineUrl} target="_blank" rel="noopener" class="text-skin-base hover:text-skin-accent transition-colors duration-300">加入 LINE</a>
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });

    // Close menu when clicking on links
    const links = menu.querySelectorAll('a');
    links.forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
      });
    });
  }
</script>
