---
import { siteData } from '../data/site';
---

<section class="relative h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <img
      src="/placeholder/hero.jpg"
      alt="Hero background"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-black/50"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center max-w-2xl mx-auto px-6">
    <h2 class="text-5xl md:text-6xl font-serif text-white mb-6 tracking-wide">
      {siteData.shopName}
    </h2>

    <!-- Decorative Line -->
    <div class="w-20 h-1 bg-skin-accent mx-auto mb-6"></div>

    <p class="text-lg md:text-xl text-skin-base mb-8 leading-relaxed">
      {siteData.tagline}
    </p>

    <!-- CTA Button -->
    <a
      href="#location"
      class="inline-block px-8 py-3 bg-skin-accent text-white font-semibold rounded-lg hover:bg-[#c97be6] transition-all duration-300 transform hover:scale-105 shadow-lg"
    >
      預約美甲服務
    </a>
  </div>
</section>
